rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Quy tắc cho bộ sưu tập kết quả dự đoán (ví dụ tên là 'predictions')
    match /predictions/{document=**} {
      // Cho phép mọi người xem kết quả dự đoán
      allow read: if true;
      
      // Chỉ cho phép ghi dữ liệu nếu người dùng đã đăng nhập (Authentication)
      // Hoặc nếu bạn chưa làm login, có thể tạm thời để 'true' nhưng phải đổi sớm
      allow write: if request.auth != null;
    }

    // Chặn tất cả các truy cập khác mặc định để bảo mật
    match /{document=**} {
      allow read, write: if false;
    }
  }
}