# ============================================================
# ENVIRONMENT FLAG — controls behavior across all modules
# ============================================================
ENVIRONMENT=development          # development | staging | production

# ============================================================
# GOOGLE AUTHENTICATION
# ============================================================

# --- Local development only (AI Studio key) ---
# Production trên GCP sẽ dùng ADC, không cần var này
GOOGLE_API_KEY=your_key_from_aistudio_google_com

# --- ADC cho local dev khi muốn test Vertex AI ---
# Trỏ đến Service Account JSON tải từ GCP Console
# Trên Cloud Run/Vertex AI: XÓA dòng này, ADC tự inject
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service_account.json

# --- SDK switch: AI Studio vs Vertex AI ---
# false = dùng GOOGLE_API_KEY (local dev)
# true  = dùng ADC + Vertex AI (production)
GOOGLE_GENAI_USE_VERTEXAI=false   # đổi thành true khi deploy production

# ============================================================
# GOOGLE CLOUD PROJECT
# ============================================================
GOOGLE_CLOUD_PROJECT=toxagent-2026
GOOGLE_CLOUD_LOCATION=asia-southeast1        # Vertex AI infra region

# Gemini model location — TÁCH RIÊNG vì model availability khác infra
# Dùng "global" hoặc "us-central1" nếu model không có ở asia-southeast1
GEMINI_LOCATION=us-central1

# Model name — centralize ở đây thay vì hardcode trong code
GEMINI_MODEL=gemini-2.0-flash-001

# Optional model overrides for each ADK role.
AGENT_MODEL_FAST=gemini-2.5-flash
AGENT_MODEL_PRO=gemini-2.5-pro

# PubMed API key is optional, but recommended to raise rate limits.
PUBMED_API_KEY=

# ============================================================
# MODEL SERVER
# ============================================================
# Local dev: http://localhost:8000
# Production (Cloud Run): https://model-server-xxxx-as.a.run.app
MODEL_SERVER_URL=http://localhost:8000
MODEL_SERVER_TIMEOUT=30          # seconds, tránh request treo với PyTorch inference

# Vertex AI Prediction endpoint (điền sau khi deploy Vertex endpoint)
# Để trống nếu chỉ dùng Cloud Run model server
VERTEX_ENDPOINT_ID=

# ============================================================
# FIREBASE
# ============================================================
FIREBASE_PROJECT_ID=toxagent-2026

# Firebase Web config (lấy từ Firebase Console > Project Settings > General)
# Cần cho client-side SDK và một số Admin SDK operations
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=toxagent-2026.firebaseapp.com
FIREBASE_STORAGE_BUCKET=toxagent-2026.appspot.com

# Database URL (chỉ cần nếu dùng Realtime Database, không phải Firestore)
# FIREBASE_DATABASE_URL=https://toxagent-2026-default-rtdb.firebaseio.com

# ============================================================
# VERTEX AI PREDICTION ROUTES (dùng khi deploy custom container)
# ============================================================
AIP_HEALTH_ROUTE=/health
AIP_PREDICT_ROUTE=/predict
AIP_HTTP_PORT=8080

# ============================================================
# OBSERVABILITY
# ============================================================
LANGCHAIN_API_KEY=your_langsmith_key_optional
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=toxagent                   # tên project trên LangSmith

# Logging
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR