{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          },
          {
            "key": "Expires",
            "value": "0"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/health",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/extract-smiles-from-image",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/smiles/**",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/predict",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/predict/**",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/explain",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/analyze",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/agent/**",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
