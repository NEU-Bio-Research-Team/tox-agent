{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/health",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/predict",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/predict/**",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/explain",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/analyze",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/agent/**",
        "run": {
          "serviceId": "tox-agent-cpu",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}